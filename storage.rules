rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // KYC photos
    match /kyc/{userId}/{allPaths=**} {
      allow write: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Photo drops — any signed-in user can upload and read
    match /photoDrops/{userId}/{allPaths=**} {
      allow write: if request.auth != null;
      allow read: if request.auth != null;
    }

    // Photo challenges — any signed-in user can upload and read
    match /photoChallenges/{userId}/{allPaths=**} {
      allow write: if request.auth != null;
      allow read: if request.auth != null;
    }
  }
}
